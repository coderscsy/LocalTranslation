<Window x:Class="LocalTranslator.App.ModelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="本地模型管理"
        Width="720"
        Height="650"
        MinWidth="640"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="28,23,28,20"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="{StaticResource TextBrush}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Text="本地模型管理" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               Text="查看离线 OCR、自有 GGUF 与通用 OpenAI-compatible 服务状态。" />
                </StackPanel>
                <Border Grid.Column="1"
                        Padding="11,6"
                        VerticalAlignment="Center"
                        Background="#ECFDF3"
                        CornerRadius="14">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7"
                                 Height="7"
                                 Margin="0,0,7,0"
                                 VerticalAlignment="Center"
                                 Fill="{StaticResource SuccessBrush}" />
                        <TextBlock Foreground="#027A48"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Text="本地优先" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Padding="28,22,28,18"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="20,17"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,13">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="PP-OCRv5 Mobile" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           Text="中文 · English · 日本語统一识别模型" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Padding="10,5"
                                    VerticalAlignment="Center"
                                    Background="#ECFDF3"
                                    CornerRadius="12">
                                <TextBlock x:Name="OcrSummaryText"
                                           Foreground="#027A48"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding OcrModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Margin="1,0,8,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding StatusBrush}" />
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="11"
                                                       Text="{Binding Name}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Margin="10,0,12,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#98A2B3"
                                                   FontFamily="Consolas"
                                                   FontSize="10"
                                                   Text="{Binding RelativePath}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding StatusBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding StatusText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Padding="20,17"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="本机离线翻译" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           Text="注册自己的 GGUF；路径、上下文和翻译提示词均可编辑" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Padding="10,5"
                                    VerticalAlignment="Center"
                                    Background="#ECFDF3"
                                    CornerRadius="12">
                                <TextBlock x:Name="OfflineSummaryText"
                                           Foreground="#027A48"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <Button Margin="0,0,0,8" Padding="12,7" HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryButtonStyle}" Content="＋ 添加本地模型"
                                Click="AddLocalModel_Click" />

                        <ItemsControl ItemsSource="{Binding OfflineModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,5"
                                            Padding="12,10"
                                            Background="#F8F9FC"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="9">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Foreground="{StaticResource TextBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding DisplayName}" />
                                                    <Border Margin="8,0,0,0"
                                                            Padding="7,2"
                                                            Background="#EAEBFF"
                                                            CornerRadius="8">
                                                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                                                   FontSize="9"
                                                                   Text="{Binding SizeText}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Margin="0,5,12,0"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="10"
                                                           Text="{Binding Description}" />
                                                <Grid Margin="0,8,12,0"
                                                      Visibility="{Binding ProgressVisibility}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ProgressBar Height="5"
                                                                 Maximum="100"
                                                                 Value="{Binding Progress, Mode=OneWay}" />
                                                    <TextBlock Grid.Column="1"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="9"
                                                               Text="{Binding StatusText}" />
                                                </Grid>
                                            </StackPanel>

                                            <WrapPanel Grid.Row="1"
                                                       Grid.ColumnSpan="2"
                                                       Margin="0,10,0,0"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center">
                                                <TextBlock Margin="0,0,10,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding StatusBrush}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding StatusText}" />
                                                <Button Padding="11,6"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Content="安装"
                                                        Tag="{Binding Id}"
                                                        Visibility="{Binding InstallVisibility}"
                                                        Click="InstallOfflineModel_Click" />
                                                <Button Padding="11,6"
                                                        Margin="6,0,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="卸载并删除文件"
                                                        Tag="{Binding Id}"
                                                        Visibility="{Binding UninstallVisibility}"
                                                        Click="UninstallOfflineModel_Click" />
                                                <Button Margin="6,0,0,0" Padding="11,6"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="设为当前" Visibility="{Binding ActivateVisibility}"
                                                        Click="ActivateLocalModel_Click" />
                                                <Button Margin="6,0,0,0" Padding="11,6"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="编辑" Click="EditLocalModel_Click" />
                                                <Button Margin="6,0,0,0" Padding="11,6"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="移除配置" Click="RemoveLocalModel_Click" />
                                                <Button Margin="6,0,0,0" Padding="11,6"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="取消"
                                                        Tag="{Binding Id}"
                                                        Visibility="{Binding ProgressVisibility}"
                                                        Click="CancelOfflineModelInstall_Click" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Padding="20,17"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextBrush}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Text="本地 / 局域网翻译服务" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="11"
                                           Text="OpenAI-compatible · LM Studio / Ollama / vLLM / llama.cpp" />
                            </StackPanel>
                            <Border x:Name="TranslationSummaryBadge"
                                    Grid.Column="1"
                                    Padding="10,5"
                                    VerticalAlignment="Center"
                                    Background="#FFF7E8"
                                    CornerRadius="12">
                                <TextBlock x:Name="TranslationSummaryText"
                                           Foreground="#B54708"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding TranslationModels}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Margin="1,0,8,0"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding StatusBrush}" />
                                            <TextBlock VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextBrush}"
                                                       FontSize="11"
                                                       Text="{Binding Name}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Margin="10,0,12,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#98A2B3"
                                                   FontFamily="Consolas"
                                                   FontSize="10"
                                                   Text="{Binding RelativePath}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="2"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding StatusBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding StatusText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                            <Button Padding="14,8"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="配置地址与模型"
                                    Click="ConfigureService_Click" />
                            <Button x:Name="TestMacAiButton"
                                    Margin="8,0,0,0"
                                    Padding="14,8"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="测试当前 Provider"
                                    Click="TestMacAi_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Margin="0,14,0,0"
                        Padding="14,11"
                        Background="#EEF4FF"
                        BorderBrush="#D8E5FF"
                        BorderThickness="1"
                        CornerRadius="10">
                    <TextBlock Foreground="#3448A5"
                               FontSize="11"
                               TextWrapping="Wrap">
                        <Run Text="模型目录：" />
                        <Run Text="{Binding ModelsRoot, Mode=OneWay}" />
                    </TextBlock>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="28,15"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Button Padding="13,8"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="打开模型目录"
                            Click="OpenModelsFolder_Click" />
                    <Button Margin="8,0,0,0"
                            Padding="13,8"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="刷新状态"
                            Click="Refresh_Click" />
                </StackPanel>
                <Button Padding="20,8"
                        HorizontalAlignment="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Content="完成"
                        Click="Close_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
