<Window x:Class="LocalTranslator.App.StyledConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认操作"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Margin="12" Padding="24"
            Background="White"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.18"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="38"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="32" Height="32" VerticalAlignment="Top"
                        Background="#E9EAFE" CornerRadius="10">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="17" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Text="i"/>
                </Border>
                <TextBlock x:Name="TitleText" Grid.Column="1" Margin="8,3,0,0"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
            </Grid>
            <TextBlock x:Name="MessageText" Grid.Row="1" Margin="46,12,0,22"
                       FontSize="12.5" LineHeight="21" TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}"/>
            <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button MinWidth="88" Height="40" Margin="0,0,10,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Content="取消" Click="Cancel_Click"/>
                <Button x:Name="ConfirmButton" MinWidth="112" Height="40"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Confirm_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
