<Window x:Class="LocalTranslator.App.SubtitleOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Local Translator 字幕"
        Width="620"
        Height="150"
        MinWidth="520"
        MinHeight="118"
        MaxHeight="520"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Grid x:Name="InteractionSurface"
          Background="Transparent"
          MouseLeftButtonDown="InteractionSurface_MouseLeftButtonDown">
        <Border x:Name="SubtitlePanel"
                Margin="6"
                Padding="12"
                VerticalAlignment="Stretch"
                CornerRadius="14"
                Cursor="SizeAll"
                ContextMenuOpening="SubtitlePanel_ContextMenuOpening"
                MouseLeftButtonDown="SubtitlePanel_MouseLeftButtonDown">
            <Border.ContextMenu>
                <ContextMenu Padding="4">
                    <MenuItem Header="放大字幕" Click="IncreaseSubtitleFont_Click" />
                    <MenuItem Header="缩小字幕" Click="DecreaseSubtitleFont_Click" />
                    <MenuItem x:Name="ToggleSourceMenuItem" Header="关闭原文" Click="ToggleSource_Click" />
                    <MenuItem x:Name="ToggleExpandedMenuItem" Header="展开字幕" Click="ToggleExpanded_Click" />
                    <Separator />
                    <MenuItem x:Name="ClickThroughMenuItem" Header="鼠标穿透" IsCheckable="True"
                              Click="ClickThroughMenuItem_Click" />
                    <MenuItem Header="重置字幕位置" Click="ResetPositionMenuItem_Click" />
                    <Separator />
                    <MenuItem Header="关闭视频字幕" Click="CloseSubtitleMenuItem_Click" />
                </ContextMenu>
            </Border.ContextMenu>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop x:Name="SubtitlePanelTopStop" Offset="0" Color="#E6363636" />
                    <GradientStop x:Name="SubtitlePanelBottomStop" Offset="1" Color="#E6303030" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" Direction="270" Opacity="0.45"
                                  ShadowDepth="5" Color="#000000" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid x:Name="ToolbarPanel" MinHeight="24">
                    <Grid.Resources>
                        <Style x:Key="OverlayToolButtonStyle" TargetType="Button">
                            <Setter Property="Padding" Value="6,2" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="#F2F2F2" />
                            <Setter Property="FontSize" Value="11" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#2FFFFFFF" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#45FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="TargetLanguageButton" Grid.Column="0"
                            Style="{StaticResource OverlayToolButtonStyle}" Content="🌐  翻译为：简体中文 ▼"
                            Click="TargetLanguageButton_Click" />
                    <Button x:Name="ToggleSourceButton" Grid.Column="1" Margin="10,0,0,0"
                            Style="{StaticResource OverlayToolButtonStyle}" Content="▣  关闭原文"
                            Click="ToggleSource_Click" />
                    <Button x:Name="FontSizeButton" Grid.Column="2" Margin="10,0,0,0"
                            Style="{StaticResource OverlayToolButtonStyle}" Content="Aₐ  中号字体 ▼"
                            Click="CycleFontSize_Click" />
                    <Button x:Name="ToggleExpandedButton" Grid.Column="4" Margin="10,0,0,0"
                            Style="{StaticResource OverlayToolButtonStyle}" Content="↗  展开字幕"
                            Click="ToggleExpanded_Click" />
                    <Button Grid.Column="5" Width="22" Height="22" Margin="6,0,0,0" Padding="0"
                            Style="{StaticResource OverlayToolButtonStyle}" Content="×"
                            Click="CloseSubtitleButton_Click" />
                </Grid>

                <Border Grid.Row="1" Margin="0,5,0,8" Background="#22FFFFFF" />

                <ScrollViewer x:Name="SubtitleScrollViewer"
                              Grid.Row="2"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="SubtitleItemsControl" VerticalAlignment="Top">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,14">
                                    <TextBlock HorizontalAlignment="Left"
                                               MaxWidth="{Binding MaxTextWidth}"
                                               Foreground="#B8B8B8"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               FontSize="{Binding SourceFontSize}"
                                               FontWeight="SemiBold"
                                               LineHeight="{Binding SourceLineHeight}"
                                               Opacity="{Binding SourceOpacity}"
                                               Text="{Binding SourceText}"
                                               TextAlignment="Left"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding SourceVisibility}">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="2" Direction="270" Opacity="0.35"
                                                              ShadowDepth="1" Color="#000000" />
                                        </TextBlock.Effect>
                                    </TextBlock>

                                    <TextBlock Margin="0,4,0,0"
                                               HorizontalAlignment="Left"
                                               MaxWidth="{Binding MaxTextWidth}"
                                               Foreground="White"
                                               FontFamily="Segoe UI, Microsoft YaHei UI"
                                               FontSize="{Binding TranslationFontSize}"
                                               FontWeight="{Binding TranslationFontWeight}"
                                               LineHeight="{Binding TranslationLineHeight}"
                                               Opacity="{Binding TranslationOpacity}"
                                               Text="{Binding TranslationText}"
                                               TextAlignment="Left"
                                               TextWrapping="Wrap">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="4" Direction="270" Opacity="0.75"
                                                              ShadowDepth="1" Color="#000000" />
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border x:Name="InteractionHint"
                        Margin="0,-34,0,0"
                        Padding="10,4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Background="#DD252525"
                        CornerRadius="9"
                        IsHitTestVisible="False"
                        Opacity="0">
                    <TextBlock Foreground="White" FontSize="10"
                               Text="拖动移动 · 右键设置 · Ctrl+Shift+F8 鼠标穿透" />
                </Border>
            </Grid>
        </Border>

        <Thumb x:Name="TopResizeThumb"
               Panel.ZIndex="19"
               Height="10"
               VerticalAlignment="Top"
               Cursor="SizeNS"
               DragStarted="ResizeThumb_DragStarted"
               DragDelta="TopResizeThumb_DragDelta"
               DragCompleted="ResizeThumb_DragCompleted"
               Opacity="0" />
        <Thumb x:Name="BottomResizeThumb"
               Panel.ZIndex="19"
               Height="10"
               VerticalAlignment="Bottom"
               Cursor="SizeNS"
               DragStarted="ResizeThumb_DragStarted"
               DragDelta="BottomResizeThumb_DragDelta"
               DragCompleted="ResizeThumb_DragCompleted"
               Opacity="0" />
        <Thumb x:Name="LeftResizeThumb"
               Panel.ZIndex="19"
               Width="10"
               HorizontalAlignment="Left"
               Cursor="SizeWE"
               DragStarted="ResizeThumb_DragStarted"
               DragDelta="LeftResizeThumb_DragDelta"
               DragCompleted="ResizeThumb_DragCompleted"
               Opacity="0" />
        <Thumb x:Name="RightResizeThumb"
               Panel.ZIndex="19"
               Width="10"
               HorizontalAlignment="Right"
               Cursor="SizeWE"
               DragStarted="ResizeThumb_DragStarted"
               DragDelta="RightResizeThumb_DragDelta"
               DragCompleted="ResizeThumb_DragCompleted"
               Opacity="0" />

        <Thumb x:Name="ResizeThumb"
               Panel.ZIndex="20"
               Width="30"
               Height="30"
               Margin="0,0,4,4"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Cursor="SizeNWSE"
               DragStarted="ResizeThumb_DragStarted"
               DragDelta="BottomRightResizeThumb_DragDelta"
               DragCompleted="ResizeThumb_DragCompleted"
               Opacity="0">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Grid Background="#01000000">
                        <Path Margin="7" Data="M 3 17 L 17 3 M 10 17 L 17 10"
                              Stroke="White" StrokeThickness="2"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Grid>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</Window>
