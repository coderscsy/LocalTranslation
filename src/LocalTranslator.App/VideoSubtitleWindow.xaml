<Window x:Class="LocalTranslator.App.VideoSubtitleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="视频实时字幕" Width="1040" Height="820" MinWidth="900" MinHeight="700"
        WindowStartupLocation="CenterOwner" Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="26">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock FontSize="25" FontWeight="SemiBold" Text="视频对话实时翻译"/>
            <TextBlock Margin="0,5,0,0" Foreground="{StaticResource MutedTextBrush}"
                       Text="采集当前输出设备的系统声音，Whisper 本地识别人物对话，再由当前翻译 Provider 生成字幕。"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" Margin="0,18,0,14"
                      Focusable="False"
                      HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Resources>
                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource VsLikeScrollBarStyle}" />
            </ScrollViewer.Resources>
        <StackPanel Margin="0,0,8,0">
        <Border Padding="18" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel Grid.ColumnSpan="2">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Text="语音识别引擎"/>
                            <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                       Text="默认推荐 SenseVoice Small；Whisper GGML 作为内置 fallback。"/>
                        </StackPanel>
                        <Border Grid.Column="1" Padding="10,5" VerticalAlignment="Center" Background="#FFF7E8" CornerRadius="12">
                            <TextBlock x:Name="DefaultModelStatusText" FontSize="11" FontWeight="SemiBold" Foreground="#B54708" Text="未安装"/>
                        </Border>
                    </Grid>
                    <Grid Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="ASR 引擎"/>
                            <ComboBox x:Name="AsrEngineCombo" Margin="0,7,0,0" Height="42"
                                      ItemsSource="{Binding AsrEngines}"
                                      SelectionChanged="AsrEngine_SelectionChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="SenseVoice / FunASR 本地服务地址"/>
                            <TextBox x:Name="SenseVoiceUrlBox" Margin="0,7,0,0" Height="42"
                                     Text="http://127.0.0.1:8899/v1"
                                     ToolTip="填写本机或局域网 FunASR OpenAI-compatible ASR 地址，例如 http://127.0.0.1:8899/v1"/>
                        </StackPanel>
                        <Button x:Name="TestAsrButton" Grid.Column="2" Height="42" Margin="8,19,0,0"
                                Padding="12,0" Style="{StaticResource SecondaryButtonStyle}"
                                Content="测试 ASR 服务" Click="TestAsrService_Click"/>
                        <WrapPanel Grid.Row="1" Grid.Column="0" Margin="0,10,12,0" VerticalAlignment="Center">
                            <CheckBox x:Name="EnableSenseVoiceCheck" IsChecked="True" Content="启用 SenseVoice"
                                      Checked="AsrEngineAvailability_Changed" Unchecked="AsrEngineAvailability_Changed"/>
                            <CheckBox x:Name="EnableWhisperCheck" Margin="14,0,0,0" IsChecked="True" Content="启用 Whisper"
                                      Checked="AsrEngineAvailability_Changed" Unchecked="AsrEngineAvailability_Changed"/>
                        </WrapPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,10,0,0">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="SenseVoice / FunASR 模型名"/>
                            <TextBox x:Name="SenseVoiceModelBox" Margin="0,7,0,0" Height="42"
                                     Text="sensevoice"
                                     ToolTip="填写 FunASR/OpenAI-compatible ASR 暴露的模型名，例如 fun-asr-nano、SenseVoiceSmall 或你的自定义模型名。"/>
                        </StackPanel>
                        <Grid Grid.Row="2" Grid.ColumnSpan="3" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,10,0">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="ASR 服务启动命令"/>
                                <TextBox x:Name="AsrStartCommandBox" Margin="0,7,0,0" Height="42"
                                         Text="funasr-server --host 127.0.0.1 --port 8899 --device cpu --model sensevoice"
                                         ToolTip="默认使用 FunASR OpenAI-compatible 服务；如果你的命令不同，可以在这里修改。"/>
                            </StackPanel>
                            <Button x:Name="ResetAsrCommandButton" Grid.Column="1" Height="42" Margin="0,19,8,0"
                                    Padding="12,0" Style="{StaticResource SecondaryButtonStyle}"
                                    Content="恢复默认" ToolTip="恢复软件内置的安全启动命令"
                                    Click="ResetAsrCommand_Click"/>
                            <Button x:Name="InstallAsrDependenciesButton" Grid.Column="2" Height="42" Margin="0,19,8,0"
                                    Padding="12,0" Style="{StaticResource SecondaryButtonStyle}"
                                    Content="安装依赖" Click="InstallAsrDependencies_Click"/>
                            <Button x:Name="StartAsrServerButton" Grid.Column="3" Height="42" Margin="0,19,0,0"
                                    Padding="12,0" Style="{StaticResource PrimaryButtonStyle}"
                                    Content="启动 ASR 服务" Click="ToggleAsrServer_Click"/>
                        </Grid>
                        <Border x:Name="AsrStatusBorder"
                                Grid.Row="3" Grid.ColumnSpan="3" Margin="0,12,0,0"
                                Padding="14,12" Background="#F7F8FC"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="24" Height="24" VerticalAlignment="Top"
                                        Background="#E9EAFE" CornerRadius="12">
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}" Text="i"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock x:Name="AsrStatusText"
                                               FontSize="11.5"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Text="ASR 状态会在这里显示，测试结果无需滚动到底部查看。"/>
                                    <StackPanel x:Name="AsrDependencyProgressPanel"
                                                Margin="0,9,0,0" Visibility="Collapsed">
                                        <ProgressBar x:Name="AsrDependencyProgress"
                                                     Height="5" IsIndeterminate="True"/>
                                        <TextBlock x:Name="AsrDependencyProgressText"
                                                   Margin="0,6,0,0" FontSize="10.5"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Margin="0,12,0,0" Padding="14,12" Background="#F8F9FC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="DefaultModelPathText" FontFamily="Consolas" FontSize="10" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis"/>
                                <StackPanel x:Name="DefaultModelProgressPanel" Margin="0,8,15,0" Visibility="Collapsed">
                                    <ProgressBar x:Name="DefaultModelProgress" Height="6" Maximum="100"/>
                                    <TextBlock x:Name="DefaultModelProgressText" Margin="0,5,0,0" FontSize="10" Foreground="{StaticResource MutedTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <Button x:Name="InstallDefaultModelButton" Padding="14,8" Style="{StaticResource PrimaryButtonStyle}"
                                        Content="下载安装默认模型" Click="InstallDefaultModel_Click"/>
                                <Button x:Name="UninstallDefaultModelButton" Margin="8,0,0,0" Padding="14,8" Style="{StaticResource SecondaryButtonStyle}"
                                        Content="卸载默认模型" Visibility="Collapsed" Click="UninstallDefaultModel_Click"/>
                                <Button x:Name="CancelDefaultDownloadButton" Margin="8,0,0,0" Padding="14,8" Style="{StaticResource SecondaryButtonStyle}"
                                        Content="取消下载" Visibility="Collapsed" Click="CancelDefaultDownload_Click"/>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <TextBlock x:Name="WhisperModelTitle" Margin="0,14,0,0" FontSize="12" FontWeight="SemiBold" Text="Whisper GGML 模型（仅 Whisper 引擎使用）"/>
                    <Grid Margin="0,7,0,12"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="ModelPathBox" Height="42"/>
                        <Button Grid.Column="1" Margin="8,0,0,0" Padding="16,7" Style="{StaticResource SecondaryButtonStyle}" Content="浏览文件" Click="BrowseModel_Click"/>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Row="2" Margin="0,0,8,0">
                    <TextBlock Text="源语言"/><ComboBox x:Name="SourceCombo" Margin="0,6,0,0" Height="40" ItemsSource="{Binding SourceLanguages}"
                                                        ItemTemplate="{StaticResource LanguageItemTemplate}"/>
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="目标语言"/><ComboBox x:Name="TargetCombo" Margin="0,6,0,0" Height="40" ItemsSource="{Binding TargetLanguages}"
                                                        ItemTemplate="{StaticResource LanguageItemTemplate}"
                                                        SelectionChanged="TargetCombo_SelectionChanged"/>
                </StackPanel>
                <WrapPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,15,0,0" Orientation="Horizontal">
                    <RadioButton x:Name="LiveModeRadio" IsChecked="True" VerticalAlignment="Center" Content="实时字幕"/>
                    <RadioButton x:Name="MovieModeRadio" Margin="20,0,0,0" VerticalAlignment="Center" Content="电影模式（记录时间轴）"/>
                    <CheckBox x:Name="BilingualCheck" Margin="25,0,0,0" IsChecked="True" VerticalAlignment="Center" Content="双语字幕"/>
                    <CheckBox x:Name="OverlayCheck" Margin="20,0,0,0" IsChecked="True" VerticalAlignment="Center" Content="屏幕叠加字幕"/>
                    <CheckBox x:Name="OverlayInteractionCheck" Margin="20,0,0,0" IsChecked="True" VerticalAlignment="Center"
                              Content="鼠标拖动/缩放" Checked="OverlayInteraction_Changed" Unchecked="OverlayInteraction_Changed"/>
                    <Button Margin="16,-6,0,-6" Padding="12,6" Style="{StaticResource SecondaryButtonStyle}"
                            Content="重置字幕位置" Click="ResetOverlayPosition_Click"/>
                </WrapPanel>
                <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="原文大小"/>
                        <Slider x:Name="SourceFontSlider" Margin="0,7,0,0" Minimum="12" Maximum="32" Value="16" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OverlaySetting_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,14,0">
                        <TextBlock Text="译文大小"/>
                        <Slider x:Name="TranslationFontSlider" Margin="0,7,0,0" Minimum="16" Maximum="42" Value="24" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OverlaySetting_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,14,0">
                        <TextBlock Text="距屏幕底部"/>
                        <Slider x:Name="BottomOffsetSlider" Margin="0,7,0,0" Minimum="0" Maximum="650" Value="28" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="OverlaySetting_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="字幕宽度"/>
                        <Slider x:Name="OverlayWidthSlider" Margin="0,7,0,0" Minimum="520" Maximum="1100" Value="620" TickFrequency="20" IsSnapToTickEnabled="True" ValueChanged="OverlaySetting_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Margin="14,0,0,0">
                        <TextBlock Text="背景不透明度"/>
                        <Slider x:Name="OverlayOpacitySlider" Margin="0,7,0,0" Minimum="0" Maximum="0.92" Value="0.66" TickFrequency="0.02" IsSnapToTickEnabled="True" ValueChanged="OverlaySetting_Changed"/>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="5" Grid.ColumnSpan="2" Margin="0,16,0,0" Padding="16,14"
                        Background="#F8F9FC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.05*" MinWidth="220"/>
                            <ColumnDefinition Width="1.7*" MinWidth="280"/>
                            <ColumnDefinition Width="184"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Margin="0,0,14,0">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="视频翻译服务"/>
                            <ComboBox x:Name="VideoProviderCombo" Margin="0,7,0,0" Height="42" MinWidth="0"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding VideoProviders}" DisplayMemberPath="DisplayName"
                                      SelectionChanged="VideoProvider_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,14,0">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Text="翻译模型"/>
                            <ComboBox x:Name="VideoModelCombo" Margin="0,7,0,0" Height="42" MinWidth="0"
                                      HorizontalAlignment="Stretch" IsEditable="True"
                                      ItemsSource="{Binding VideoModels}"
                                      SelectionChanged="VideoModel_SelectionChanged"
                                      LostKeyboardFocus="VideoModel_LostKeyboardFocus"/>
                        </StackPanel>

                        <Button x:Name="TestVideoProviderButton" Grid.Column="2"
                                Height="42" Margin="0,25,0,0" Padding="14,0"
                                HorizontalAlignment="Stretch" VerticalAlignment="Top"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Content="选择翻译模型" Click="ChooseVideoModel_Click"/>

                        <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,13,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Margin="0,0,14,0">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="翻译场景"/>
                                <ComboBox x:Name="VideoSceneCombo" Margin="0,7,0,0" Height="42" MinWidth="0"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding VideoSceneOptions}"
                                          SelectionChanged="VideoScene_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Text="并发请求"/>
                                <ComboBox x:Name="VideoConcurrencyCombo" Margin="0,7,0,0" Height="42" MinWidth="0"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding VideoConcurrencyOptions}"
                                          SelectionChanged="VideoConcurrency_SelectionChanged"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Margin="0,11,0,0" Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,7,0" VerticalAlignment="Center"
                                     Fill="{StaticResource AccentBrush}"/>
                            <TextBlock x:Name="VideoProviderStatusText" VerticalAlignment="Center"
                                       FontSize="11" Foreground="{StaticResource MutedTextBrush}"
                                       Text="视频字幕使用独立模型配置；普通文字翻译 Provider 不受影响。"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        <Border Height="190" Margin="0,14,0,0" Padding="16" Style="{StaticResource CardStyle}">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <TextBlock x:Name="StatusText" Foreground="{StaticResource MutedTextBrush}" Text="尚未开始。播放视频后点击“开始翻译”。"/>
                <ListBox x:Name="SubtitleList" Grid.Row="1" Margin="0,12,0,0" BorderThickness="0" Background="Transparent">
                    <ListBox.ItemTemplate><DataTemplate><Border Margin="0,0,0,8" Padding="12" Background="#F8F9FC" CornerRadius="8">
                        <StackPanel><TextBlock FontSize="10" Foreground="#98A2B3" Text="{Binding TimeText}"/>
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource MutedTextBrush}" Text="{Binding SourceText}" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,4,0,0" FontSize="15" FontWeight="SemiBold" Text="{Binding TranslatedText}" TextWrapping="Wrap"/>
                        </StackPanel></Border></DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Padding="14,10"
                Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="0,0,18,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedTextBrush}" FontSize="11"
                           TextWrapping="Wrap"
                           Text="当前采集默认输出设备的全部声音；最小化后字幕继续运行。"/>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button x:Name="ExportButton" MinWidth="112" Height="42" Padding="16,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Content="导出 SRT" IsEnabled="False" Click="ExportSrt_Click"/>
                    <Button x:Name="StartButton" MinWidth="120" Height="42" Margin="10,0,0,0" Padding="18,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="开始翻译" Click="StartStop_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
