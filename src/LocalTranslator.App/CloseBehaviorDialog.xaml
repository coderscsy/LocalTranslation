<Window x:Class="LocalTranslator.App.CloseBehaviorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关闭 Local Translator"
        Width="430" Height="310"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="关闭按钮执行什么操作？" />
        <TextBlock Grid.Row="1" Margin="0,7,0,0" Foreground="{StaticResource MutedTextBrush}"
                   Text="你可以记住选择，之后可从托盘菜单重新设置。" />

        <Grid Grid.Row="2" Margin="0,22,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Height="96" Style="{StaticResource SecondaryButtonStyle}"
                    Click="MinimizeToTray_Click">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center" FontSize="22" Text="▾" />
                    <TextBlock Margin="0,5,0,0" HorizontalAlignment="Center"
                               FontSize="14" FontWeight="SemiBold" Text="缩小到托盘" />
                    <TextBlock Margin="0,3,0,0" HorizontalAlignment="Center"
                               FontSize="10" Foreground="{StaticResource MutedTextBrush}" Text="字幕继续运行" />
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Height="96" Style="{StaticResource SecondaryButtonStyle}"
                    Click="ExitApplication_Click">
                <StackPanel>
                    <TextBlock HorizontalAlignment="Center" FontSize="19" Text="×" />
                    <TextBlock Margin="0,7,0,0" HorizontalAlignment="Center"
                               FontSize="14" FontWeight="SemiBold" Text="关闭软件" />
                    <TextBlock Margin="0,3,0,0" HorizontalAlignment="Center"
                               FontSize="10" Foreground="{StaticResource MutedTextBrush}" Text="停止翻译并退出" />
                </StackPanel>
            </Button>
        </Grid>

        <CheckBox x:Name="RememberChoiceCheck" Grid.Row="3" VerticalAlignment="Center"
                  Content="记住我的选择" />
    </Grid>
</Window>
